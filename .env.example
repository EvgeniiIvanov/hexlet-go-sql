# Database Configuration
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_USER=gosql
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=gosql_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection String (auto-generated from above values)
# postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# Test Database Configuration
POSTGRES_TEST_DB=gosql_test
TEST_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_TEST_DB}?sslmode=disable

# Application Configuration
APP_ENV=development
LOG_LEVEL=info

# SQLite Configuration (alternative to PostgreSQL)
SQLITE_DB_PATH=./data.db
